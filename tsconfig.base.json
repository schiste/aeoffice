{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "composite": true,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@aedventure/protocol": [
        "packages/protocol/src"
      ],
      "@aedventure/game-protocol": [
        "packages/game-protocol/src"
      ],
      "@aedventure/game-core": [
        "packages/game-core/src"
      ],
      "@aedventure/game-topology": [
        "packages/game-topology/src"
      ],
      "@aedventure/game-world": [
        "packages/game-world/src"
      ],
      "@aedventure/add-domain": [
        "packages/add-domain/src"
      ],
      "@aedventure/map-engine": [
        "packages/map-engine/src"
      ],
      "@aedventure/game-assets": [
        "packages/game-assets/src"
      ],
      "@aedventure/game-map": [
        "packages/game-map/src"
      ],
      "@aedventure/game-input": [
        "packages/game-input/src"
      ],
      "@aedventure/game-renderer-phaser": [
        "packages/game-renderer-phaser/src"
      ],
      "@aedventure/game-renderer-phaser/hex-geometry": [
        "packages/game-renderer-phaser/src/hex/hex-geometry"
      ],
      "@aedventure/rpg-domain": [
        "packages/rpg-domain/src"
      ],
      "@aedventure/office-domain": [
        "packages/office-domain/src"
      ],
      "@aedventure/office-domain/assets": [
        "packages/office-domain/src/assets"
      ],
      "@aedventure/asset-registry": [
        "packages/asset-registry/src"
      ],
      "@aedventure/auth-wikimedia": [
        "packages/auth-wikimedia/src"
      ],
      "@aedventure/policy": [
        "packages/policy/src"
      ],
      "@aedventure/shared-types": [
        "packages/shared-types/src"
      ]
    }
  }
}
