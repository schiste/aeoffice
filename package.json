{
  "name": "aedventure-virtual-office",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "commonjs",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check": "scripts/verify-target-stack.sh",
    "check:target": "scripts/verify-target-stack.sh",
    "check:legacy": "SKIP_INSTALL=1 scripts/verify-skyoffice-baseline.sh",
    "build": "tsc -b && npm --workspace @aedventure/web run build:browser",
    "dev:http": "node scripts/dev-http-host.cjs",
    "smoke:frontend": "node scripts/frontend-smoke.test.cjs"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "typescript": "^4.8.2",
    "vite": "^8.0.14"
  },
  "engines": {
    "node": ">=20"
  }
}
