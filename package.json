{
  "name": "aedventure-virtual-office",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "commonjs",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "assets:build": "node scripts/build-internal-office-atlas.cjs",
    "assets:check": "npm --workspace @aedventure/asset-registry run build && node scripts/build-internal-office-atlas.cjs --check && node scripts/verify-internal-assets.cjs",
    "content:build": "npm --workspace @aedventure/game-content run build && node scripts/build-add-content.cjs",
    "content:check": "npm --workspace @aedventure/game-content run build && node scripts/build-add-content.cjs --check",
    "check": "scripts/verify-target-stack.sh",
    "check:target": "scripts/verify-target-stack.sh",
    "check:legacy": "SKIP_INSTALL=1 scripts/verify-skyoffice-baseline.sh",
    "build": "tsc -b && npm --workspace @aedventure/web run build:browser",
    "dev:http": "npm run build && node scripts/dev-http-host.cjs",
    "qa:responsive": "node scripts/responsive-layout-qa.test.cjs",
    "qa:multi-app": "node scripts/multi-app-qa-contracts.test.cjs",
    "qa:renderer": "npm --workspace @aedventure/web run build:browser && npm --workspace @aedventure/engine-sandbox run build:browser && npm --workspace @aedventure/add-rpg run build:browser && node scripts/renderer-qa.test.cjs",
    "qa:renderer:built": "node scripts/renderer-qa.test.cjs",
    "smoke:apps": "npm run smoke:office && npm run smoke:engine-sandbox && npm run smoke:add-rpg",
    "smoke:office": "npm --workspace @aedventure/web run build:browser && node scripts/frontend-smoke.test.cjs",
    "smoke:office:built": "node scripts/frontend-smoke.test.cjs",
    "smoke:engine-sandbox": "npm --workspace @aedventure/engine-sandbox run smoke",
    "smoke:engine-sandbox:built": "node scripts/engine-sandbox-smoke.test.cjs",
    "smoke:add-rpg": "npm --workspace @aedventure/add-rpg run smoke",
    "smoke:add-rpg:built": "node scripts/add-rpg-smoke.test.cjs",
    "smoke:frontend": "npm run smoke:office:built"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "typescript": "^4.8.2",
    "vite": "^8.0.14"
  },
  "engines": {
    "node": ">=20"
  }
}
