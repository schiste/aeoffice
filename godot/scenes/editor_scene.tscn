[node name="HelpLabel" type="Label" parent="CanvasLayer/UI/HelpPanel"]
layout_mode = 2
text = "Controls (Magic Mouse):
Click: Paint / tool action
Two-finger scroll: Pan
Pinch: Zoom
Ctrl+click: Cycle terrain
Shift+click: Add new hex
E / Shift+E: Elevation +/-
Del/Backspace: Delete hex (or clear selection)
[ / ]: Brush size
0-9: Select terrain
Cmd+Z/Shift+Z: Undo/Redo
Cmd+S / Cmd+O: Save/Load
Cmd+V: Validate map
Cmd+Shift+V: Paste stamp
Cmd+C / Cmd+X: Copy/Cut selection"

