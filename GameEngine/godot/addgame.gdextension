[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.3
reloadable = true

[libraries]
macos.debug = "res://bin/libaddgame.dylib"
macos.release = "res://bin/libaddgame.dylib"
linux.debug.x86_64 = "res://bin/libaddgame.so"
linux.release.x86_64 = "res://bin/libaddgame.so"
windows.debug.x86_64 = "res://bin/addgame.dll"
windows.release.x86_64 = "res://bin/addgame.dll"
