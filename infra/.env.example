POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_DB=aedventure
POSTGRES_USER=aedventure
POSTGRES_PASSWORD=local_dev_password
POSTGRES_PORT=5432

VALKEY_IMAGE=valkey/valkey:7-alpine
VALKEY_PORT=6379

LIVEKIT_IMAGE=livekit/livekit-server:latest
LIVEKIT_HTTP_PORT=7880
LIVEKIT_RTC_TCP_PORT=7881
LIVEKIT_RTC_UDP_PORT_START=50000
LIVEKIT_RTC_UDP_PORT_END=50100

COTURN_IMAGE=coturn/coturn:latest
COTURN_PORT=3478
COTURN_TLS_PORT=5349
COTURN_MIN_PORT=49160
COTURN_MAX_PORT=49200
COTURN_STATIC_AUTH_SECRET=local_dev_turn_secret
COTURN_REALM=localhost

MINIO_IMAGE=minio/minio:latest
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=local_dev_minio_password
